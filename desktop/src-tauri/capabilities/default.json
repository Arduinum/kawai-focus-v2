{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "fs:allow-appconfig-read",
    "fs:allow-appconfig-write"
  ],
  "fs": {
    "read": {
      "scope": [
        "$APPCONFIG/**"
      ]
    },
    "write": {
      "scope": [
        "$APPCONFIG/**"
      ]
    }
  }
}
